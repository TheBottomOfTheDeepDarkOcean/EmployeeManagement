@using Microsoft.AspNetCore.Identity;
@model IEnumerable<IdentityUser>

@{
    ViewData["Title"] = "System Users";
}

<p>
    <a asp-action="Create" class="btn btn-primary"><i class="fa fa-plus"></i> Add New User</a>
</p>
<div class="card">
    <div class="card-header">
        <h3 class="card-title">Users List</h3>
    </div>
    <div class="card-body">
        <table id="example1" class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>
                        User Serial No
                    </th>
                    <th>
                        User Email
                    </th>
                    <th>
                        User Name
                    </th>
                    <th>
                        User PhoneNo
                    </th> 
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(modelItem => item.Id)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Email)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.NormalizedUserName)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.PhoneNumber)
                        </td>
                        <td>
                            <div class="btn-group">
                                <button type="button" class="btn btn-warning btn-sm dropdown-toggle" data-toggle="dropdown" aria-expanded="false">
                                    Action
                                </button>
        
                                <div class="dropdown-menu dropdown-menu-right p-1" style="min-width: 110px;">
            
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary btn-sm btn-block text-left mb-1" style="margin-top: 0;">
                                        <i class="fas fa-edit fa-fw"></i> Edit
                                    </a>
            
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-warning btn-sm btn-block text-left mb-1">
                                        <i class="fas fa-eye fa-fw"></i> View
                                    </a>
            
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm btn-block text-left mb-1">
                                        <i class="fas fa-trash fa-fw"></i> Delete
                                    </a>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>